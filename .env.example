# Required: Portkey API Key (get from https://app.portkey.ai/settings/api-keys)
PORTKEY_API_KEY=your_portkey_api_key_here

# Optional: Transport mode (stdio or http, default: stdio)
# MCP_TRANSPORT=stdio

# Optional: Session mode for HTTP transport
# - stateful (default): per-session in-memory transport, requires sticky routing/single instance
# - stateless: no session IDs, better for autoscaling/serverless platforms
# MCP_SESSION_MODE=stateful

# Optional: Stream resumability event store
# - off (default in stateful mode)
# - memory (default in stateless mode)
# - redis (shared resumability across instances)
# MCP_EVENT_STORE=memory

# Optional: Event retention TTL in seconds (default: 3600)
# MCP_EVENT_TTL_SECONDS=3600

# Optional: Redis URL for MCP_EVENT_STORE=redis (MCP_REDIS_URL takes precedence over REDIS_URL)
# MCP_REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Optional: Redis key prefix for event store keys (default: mcp:event-store)
# MCP_REDIS_KEY_PREFIX=mcp:event-store

# Optional: HTTP server port (default: 3000, only used when MCP_TRANSPORT=http)
# MCP_PORT=3000

# Optional: HTTP server host (default: 0.0.0.0, only used when MCP_TRANSPORT=http)
# MCP_HOST=0.0.0.0

# Optional: Express trust proxy setting (default: loopback)
# Set to "true" on hosted platforms like Vercel/Render/Cloud Run.
# MCP_TRUST_PROXY=true

# Optional: Native HTTPS (in-app TLS).
# For cloud hosting, you can usually leave these unset and terminate HTTPS at your platform/proxy.
# MCP_TLS_KEY_PATH=/absolute/path/to/tls.key
# MCP_TLS_CERT_PATH=/absolute/path/to/tls.crt
# MCP_TLS_CA_PATH=/absolute/path/to/ca.pem

# Optional: Session timeout in milliseconds (default: 3600000 = 1 hour)
# MCP_SESSION_TIMEOUT=3600000

# Optional: Allowed origins for CORS + origin validation (comma-separated)
# Use "*" only for development.
# ALLOWED_ORIGINS=http://localhost,https://localhost

# Optional legacy alias for allowed origins (used if ALLOWED_ORIGINS is not set)
# CORS_ORIGIN=http://localhost,https://localhost

# Optional: Request body size limit (default: 1mb)
# MCP_MAX_REQUEST_SIZE=1mb

# Optional: Readiness mode
# - local: process/session readiness only
# - portkey: includes Portkey API ping via /configs
# MCP_READY_CHECK_MODE=local

# Optional: HTTP auth mode for /mcp endpoint
# - none: no auth (default, local development only; NEVER use in production/public deployments)
#   Risk: unauthenticated access to /mcp
# - bearer: static shared bearer token
# - clerk: verify Clerk JWT via JWKS
# MCP_AUTH_MODE=none

# Optional: Shared bearer token when MCP_AUTH_MODE=bearer
# MCP_AUTH_TOKEN=replace_with_long_random_secret

# Optional: Clerk JWT verification settings when MCP_AUTH_MODE=clerk
# Required: CLERK_ISSUER and CLERK_AUDIENCE
# Optional override: CLERK_JWKS_URL (auto-derived from CLERK_ISSUER if omitted)
# CLERK_ISSUER=https://your-clerk-domain
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
# CLERK_AUDIENCE=your-audience

# Optional: Enable/disable rate limiting for HTTP mode (default: true)
# RATE_LIMIT_ENABLED=true

# Optional: Max tokens in bucket (default: 60)
# RATE_LIMIT_MAX=60

# Optional: Rate limit window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Optional: Tokens refilled each window (default: 60)
# RATE_LIMIT_REFILL=60
