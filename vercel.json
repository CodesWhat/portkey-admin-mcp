{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"functions": {
		"api/index.ts": {
			"maxDuration": 300
		}
	},
	"rewrites": [
		{
			"source": "/",
			"destination": "/api/index"
		},
		{
			"source": "/mcp",
			"destination": "/api/index"
		},
		{
			"source": "/health",
			"destination": "/api/index"
		},
		{
			"source": "/ready",
			"destination": "/api/index"
		},
		{
			"source": "/auth/info",
			"destination": "/api/index"
		},
		{
			"source": "/authorize",
			"destination": "/api/index"
		},
		{
			"source": "/token",
			"destination": "/api/index"
		},
		{
			"source": "/register",
			"destination": "/api/index"
		},
		{
			"source": "/revoke",
			"destination": "/api/index"
		},
		{
			"source": "/oauth/callback",
			"destination": "/api/index"
		},
		{
			"source": "/.well-known/:path*",
			"destination": "/api/index"
		}
	]
}
